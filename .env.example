# Google Cloud OAuth (Desktop App)
CLIENT_ID=your-client-id.apps.googleusercontent.com
CLIENT_SECRET=GOCSPX-your-secret

# YouTube Data API Key
API_KEY=AIzaSy-your-api-key

# Google Cloud Project
GCP_PROJECT=your-project-id

# YouTube Channel ID
YOUTUBE_CHANNEL_ID=UC-your-channel-id

# Google Spreadsheet ID (dashboard data)
SPREADSHEET_ID=your-spreadsheet-id

# Diretorio de lives processadas (Docker: /data/lives)
# LIVES_DIR=/data/lives
